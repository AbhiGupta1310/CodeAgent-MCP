# CodeAgent MCP Environment Variables

# PostgreSQL connection string (Neon free tier recommended)
# Get yours at: https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# OpenRouter API key (only needed for CLI "codeagent ask" command)
# Get yours at: https://openrouter.ai
OPENROUTER_API_KEY="sk-or-..."
